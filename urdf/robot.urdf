<?xml version="1.0"?>
<robot name="supermarket_robot">

  <!-- Base -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.6" radius="0.5"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.6" radius="0.5"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="10"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1" iyy="1" izz="1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

</robot>
